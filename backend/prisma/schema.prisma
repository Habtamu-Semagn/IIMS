// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  BUREAU_ASSIGNEE
  ORG_VICE
  DIRECTORATE_HEAD
  TEAM_MEMBER
  SYSTEM_ADMIN
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     Role     @default(USER)
}
